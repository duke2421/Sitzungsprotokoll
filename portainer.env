# Portainer env file for Schriftführer
# Replace the placeholder values before productive deployment.

HOST_PORT=8090
PORT=3000
SESSION_SECRET=please-change-this-to-a-long-random-secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD=please-change-this-password
ADMIN_DISPLAY_NAME=Administrator
TRUST_PROXY_HOPS=1
COOKIE_SECURE=auto
FORCE_HTTPS=false
LOGIN_RATE_LIMIT_WINDOW_MS=600000
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5
TZ=Europe/Berlin
